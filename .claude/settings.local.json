      "Bash(curl *)",
      "Bash(tar: *)",
      "Bash(tar *)",
      "Bash(cp: *)",
      "Bash(cp *)",
      "Bash(mv: *)",
      "Bash(mv *)",
      "Bash(mkdir: *)",
      "Bash(mkdir *)",
      "Bash(rm: *)",
      "Bash(rm *)",
      "Bash(chmod: *)",
      "Bash(chmod *)",
      "Bash(sudo: *)",
      "Bash(sudo *)",
      "Bash(apt: *)",
      "Bash(apt *)",
      "Bash(which: *)",
      "Bash(which *)",
      "Bash(uname: *)",
      "Bash(uname *)",
      "Bash(echo: *)",
      "Bash(echo *)",
      "Bash(tee: *)",
      "Bash(tee *)",
      "Bash(pidof: *)",
      "Bash(pidof *)",
      "Bash(dpkg: *)",
      "Bash(dpkg *)",
      "Bash(head: *)",
      "Bash(head *)",
      "Bash(tail: *)",
      "Bash(tail *)",
      "Bash(wc: *)",
      "Bash(wc *)",
      "Bash(ip: *)",
      "Bash(ip *)",
      "Bash(hostname: *)",
      "Bash(hostname *)",
      "Bash(nproc: *)",
      "Bash(nproc *)",
      "Bash(free: *)",
      "Bash(free *)",
      "Bash(df: *)",
      "Bash(df *)",
      "Bash(sleep: *)",
      "Bash(sleep *)",
      "Bash(gh: *)",
      "Bash(gh *)",
      "Bash(LD_PRELOAD: *)",
      "Bash(LD_LIBRARY_PATH: *)",
      "Bash(gcc: *)",
      "Bash(gcc *)",
      "Bash(timeout: *)",
      "Bash(timeout *)",
      "Bash(bash: *)",
      "Bash(bash *)",
      "Bash(gdb: *)",
      "Bash(gdb *)",
      "Bash(python3: *)",
      "Bash(python3 *)",
      "Bash(ulimit: *)",
      "Bash(ulimit *)",
      "Bash(build/mttd: *)",
      "Bash(build/mttd *)",
      "Bash(build/demo: *)",
      "Bash(build/demo *)",
      "Bash(build/demo_preload: *)",
      "Bash(build/demo_preload *)",
      "Bash(build/demo_daemon: *)",
      "Bash(build/demo_daemon *)",
      "Bash(build/demo_long_running: *)",
      "Bash(build/demo_long_running *)",
      "Bash(build/demo_long_running_preload: *)",
      "Bash(build/demo_long_running_preload *)",
      "Bash(build/demo_macro_daemon: *)",
      "Bash(build/demo_macro_daemon *)",
      "Bash(build/test_basic: *)",
      "Bash(build/test_basic *)",
      "Bash(*)",
      "PowerShell(Get-Command wsl -ErrorAction SilentlyContinue)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "sleep 0.3"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "sleep 0.1"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "sleep 0.1"
          }
        ]
      }
    ]
  }
}
